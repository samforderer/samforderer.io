---
const allPosts = await Astro.glob('../pages/posts/*.md');
import BlogPost from '../components/BlogPost.astro';
---
<aside>
    <h1>Posts</h1>
    <ul>
        {allPosts.map((post) => <BlogPost url={post.url} title={post.frontmatter.title} date={post.frontmatter.pubDate}/>)}
    </ul>
</aside>

<style>
    h1 {
        color: var(--accent);
    }
    aside {
        padding: 20px;
        display: flex;
        flex-direction: column;
    }
    ul {
        padding-left: 0;
        list-style: none;
    }

    @media screen and (min-width: 636px) {
    
        aside {
            padding: 40px;
        }
    }
</style>