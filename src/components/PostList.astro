---
const allPosts = await Astro.glob('../pages/posts/*.md');
import BlogPost from '../components/BlogPost.astro';
---
<aside>
    <h1>Archive</h1>
    <ul>
        {allPosts.map((post) => <BlogPost url={post.url} title={post.frontmatter.title} date={post.frontmatter.pubDate}/>)}
        </ul>
</aside>

<style>
    aside {
        padding: 40px;
        display: flex;
        flex-direction: column;
    }
    ul {
        padding-left: 0;
        list-style: none;
    }
</style>